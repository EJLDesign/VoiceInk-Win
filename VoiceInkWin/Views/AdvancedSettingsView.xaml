<UserControl x:Class="VoiceInkWin.Views.AdvancedSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="15">
        <StackPanel>
            <TextBlock Text="Audio Input Device" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <ComboBox ItemsSource="{Binding AudioDevices}" SelectedItem="{Binding SelectedAudioDevice}"
                          Width="300" Margin="0,0,10,0"/>
                <Button Content="Refresh" Command="{Binding RefreshAudioDevicesCommand}"/>
            </StackPanel>

            <Separator Margin="0,15"/>

            <TextBlock Text="Silence Detection" FontWeight="SemiBold" FontSize="14" Margin="0,10,0,8"/>
            <TextBlock Margin="0,0,0,3">
                <Run Text="Threshold: "/>
                <Run Text="{Binding SilenceThreshold, StringFormat=F3}"/>
            </TextBlock>
            <Slider Value="{Binding SilenceThreshold}" Minimum="0.001" Maximum="0.1"
                    TickFrequency="0.005" IsSnapToTickEnabled="False" Width="300" HorizontalAlignment="Left"/>
            <TextBlock Text="Lower = more sensitive (stops recording later). Default: 0.01"
                       Foreground="Gray" FontSize="11" Margin="0,3,0,0"/>

            <Separator Margin="0,15"/>

            <TextBlock Text="Max Recording Duration" FontWeight="SemiBold" FontSize="14" Margin="0,10,0,8"/>
            <TextBlock Margin="0,0,0,3">
                <Run Text="Duration: "/>
                <Run Text="{Binding MaxRecordingDuration, StringFormat=F0}"/>
                <Run Text=" seconds"/>
            </TextBlock>
            <Slider Value="{Binding MaxRecordingDuration}" Minimum="10" Maximum="300"
                    TickFrequency="10" IsSnapToTickEnabled="True" Width="300" HorizontalAlignment="Left"/>

            <Separator Margin="0,15"/>

            <TextBlock Text="Data" FontWeight="SemiBold" FontSize="14" Margin="0,10,0,8"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="Export History" Padding="10,5" Margin="0,0,10,0" Command="{Binding ExportHistoryCommand}"/>
                <Button Content="Open AppData Folder" Padding="10,5" Command="{Binding OpenAppDataFolderCommand}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
