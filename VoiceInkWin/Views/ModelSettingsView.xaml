<UserControl x:Class="VoiceInkWin.Views.ModelSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VoiceInkWin.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="15">
        <StackPanel>
            <TextBlock Text="Whisper Model" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>

            <TextBlock Text="Select active model:" Margin="0,0,0,5"/>
            <ComboBox ItemsSource="{Binding AvailableModels}"
                      SelectedValuePath="FileName"
                      SelectedValue="{Binding SelectedModelName}"
                      Margin="0,0,0,10">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding DisplayName}" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding FileSizeDisplay}" Foreground="Gray"/>
                            <TextBlock Text=" ✓" Foreground="Green" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDownloaded}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="Available Models" FontWeight="SemiBold" FontSize="13" Margin="0,5,0,8"/>

            <ItemsControl ItemsSource="{Binding AvailableModels}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5" Margin="0,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Medium"/>
                                    <TextBlock Text="{Binding FileSizeDisplay}" Foreground="Gray" FontSize="11"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="Download" Padding="8,3"
                                            Command="{Binding DataContext.DownloadModelCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDownloaded}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <TextBlock Text="Downloaded" Foreground="Green" VerticalAlignment="Center" Margin="5,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDownloaded}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Download progress -->
            <StackPanel Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}" Margin="0,10">
                <TextBlock Text="{Binding DownloadStatus}" Margin="0,0,0,3"/>
                <ProgressBar Value="{Binding DownloadProgress}" Maximum="100" Height="20"/>
                <Button Content="Cancel" HorizontalAlignment="Left" Margin="0,5" Command="{Binding CancelDownloadCommand}"/>
            </StackPanel>

            <Separator Margin="0,15"/>

            <TextBlock Text="Transcription Settings" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <TextBlock Text="Language:" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding TranscriptionLanguage, UpdateSourceTrigger=PropertyChanged}"
                         Width="80" HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="1" Text="Translate:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                <CheckBox Grid.Row="1" Grid.Column="1" Content="Translate to English"
                          IsChecked="{Binding TranslateToEnglish}" Margin="0,8,0,0"/>

                <TextBlock Grid.Row="2" Text="Vocabulary:" VerticalAlignment="Top" Margin="0,8,0,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding VocabularyHints, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap" AcceptsReturn="True" Height="60" Margin="0,8,0,0"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
