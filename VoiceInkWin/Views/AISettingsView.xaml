<UserControl x:Class="VoiceInkWin.Views.AISettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VoiceInkWin.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="15">
        <StackPanel>
            <TextBlock Text="AI Provider" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
            <RadioButton Content="None (raw transcription only)" IsChecked="{Binding IsNoneProvider}" Margin="0,0,0,5"/>
            <RadioButton Content="Anthropic (Claude)" IsChecked="{Binding IsAnthropicProvider}" Margin="0,0,0,5"/>
            <RadioButton Content="Ollama (local)" IsChecked="{Binding IsOllamaProvider}"/>

            <!-- Anthropic settings -->
            <StackPanel Visibility="{Binding IsAnthropicProvider, Converter={StaticResource BoolToVis}}" Margin="20,10,0,0">
                <TextBlock Text="API Key:" Margin="0,0,0,3"/>
                <StackPanel Orientation="Horizontal">
                    <PasswordBox x:Name="ApiKeyBox" Width="350" Margin="0,0,10,0"
                                 PasswordChanged="ApiKeyBox_PasswordChanged"/>
                    <Button Content="Save Key" Command="{Binding SaveApiKeyCommand}"/>
                </StackPanel>
                <TextBlock Text="Key is stored securely in Windows Credential Manager"
                           Foreground="Gray" FontSize="11" Margin="0,3,0,0"/>
            </StackPanel>

            <!-- Ollama settings -->
            <StackPanel Visibility="{Binding IsOllamaProvider, Converter={StaticResource BoolToVis}}" Margin="20,10,0,0">
                <TextBlock Text="Endpoint:" Margin="0,0,0,3"/>
                <TextBox Text="{Binding OllamaEndpoint, UpdateSourceTrigger=PropertyChanged}" Width="300" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                <TextBlock Text="Model Name:" Margin="0,0,0,3"/>
                <TextBox Text="{Binding OllamaModelName, UpdateSourceTrigger=PropertyChanged}" Width="200" HorizontalAlignment="Left"/>
            </StackPanel>

            <Separator Margin="0,20"/>

            <TextBlock Text="Modes" FontWeight="SemiBold" FontSize="14" Margin="0,10,0,8"/>
            <TextBlock Text="Modes define how AI processes your transcription. 'Raw' uses no AI."
                       Foreground="Gray" FontSize="11" Margin="0,0,0,8"/>

            <ItemsControl ItemsSource="{Binding Modes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5,3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="Medium"/>
                                    <TextBlock Text="{Binding SystemPrompt}" Foreground="Gray" FontSize="11"
                                               TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Delete" Padding="6,2"
                                        Command="{Binding DataContext.DeleteModeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding IsBuiltIn, Converter={StaticResource InverseBool}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <GroupBox Header="Add Custom Mode" Margin="0,15,0,0" Padding="10">
                <StackPanel>
                    <TextBlock Text="Name:" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding NewModeName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <TextBlock Text="System Prompt:" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding NewModePrompt, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True" Height="80" Margin="0,0,0,8"/>
                    <Button Content="Add Mode" HorizontalAlignment="Left" Padding="15,5" Command="{Binding AddCustomModeCommand}"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
