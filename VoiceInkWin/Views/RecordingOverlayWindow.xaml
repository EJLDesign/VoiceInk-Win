<Window x:Class="VoiceInkWin.Views.RecordingOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceInk Recording"
        Width="280" Height="60"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        ShowInTaskbar="False" ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    <Border CornerRadius="20" Background="#DD1A1A2E" Padding="15,8" Margin="5"
            BorderBrush="#5555FF" BorderThickness="1.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" Opacity="0.4" ShadowDepth="2" Color="#5555FF"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Recording dot -->
            <Ellipse Width="10" Height="10" Fill="#FF4444" Margin="0,0,10,0" VerticalAlignment="Center">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1" To="0.3" Duration="0:0:0.8"
                                                 AutoReverse="True"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>

            <!-- Waveform bars -->
            <Canvas x:Name="WaveformCanvas" Grid.Column="1" Height="30" ClipToBounds="True"/>

            <!-- Status text -->
            <TextBlock Grid.Column="2" Text="REC" Foreground="#FF4444" FontWeight="Bold"
                       FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
        </Grid>
    </Border>
</Window>
