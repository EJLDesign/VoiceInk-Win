<UserControl x:Class="VoiceInkWin.Views.GeneralSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VoiceInkWin.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="15">
        <StackPanel>
            <TextBlock Text="Hotkey" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <Border BorderBrush="Gray" BorderThickness="1" Padding="8,4" MinWidth="200" Margin="0,0,10,0">
                    <TextBlock Text="{Binding HotkeyDisplay}" VerticalAlignment="Center"/>
                </Border>
                <Button Content="Set Hotkey" Width="90" Command="{Binding StartCaptureHotkeyCommand}" Margin="0,0,5,0"/>
                <Button Content="Clear" Width="60" Command="{Binding ClearHotkeyCommand}"/>
            </StackPanel>
            <TextBlock Text="Press your desired key combination when capturing."
                       Foreground="Gray" FontSize="11" Margin="0,0,0,4"
                       Visibility="{Binding IsCapturingHotkey, Converter={StaticResource BoolToVis}}"/>

            <Separator Margin="0,15"/>

            <TextBlock Text="Recording Mode" FontWeight="SemiBold" FontSize="14" Margin="0,10,0,8"/>
            <RadioButton Content="Toggle (press to start, press again to stop)"
                         IsChecked="{Binding IsToggleMode}" Margin="0,0,0,5"/>
            <RadioButton Content="Push-to-Talk (hold to record, release to stop)"
                         IsChecked="{Binding IsPushToTalk}"/>

            <Separator Margin="0,15"/>

            <TextBlock Text="General" FontWeight="SemiBold" FontSize="14" Margin="0,10,0,8"/>
            <CheckBox Content="Launch at Windows startup" IsChecked="{Binding LaunchAtLogin}" Margin="0,0,0,5"/>
            <CheckBox Content="Play sound on transcription complete" IsChecked="{Binding PlaySoundOnComplete}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
